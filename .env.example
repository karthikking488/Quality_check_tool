# Snowflake Connection Configuration (SSO Authentication)
# Copy this file to .env and fill in your actual credentials

# Account identifier (e.g., VOYA-VOYAIMTEST)
SNOWFLAKE_ACCOUNT=VOYA-VOYAIMTEST

# Your Voya email/username
SNOWFLAKE_USER=your_email@voya.com

# Snowflake resources
SNOWFLAKE_WAREHOUSE=WH_CORTEX_POC_READ
SNOWFLAKE_DATABASE=HACKATHON_POC
SNOWFLAKE_SCHEMA=NN
SNOWFLAKE_ROLE=ROLE_HACKATHON_POC_DDLADMIN_NN
